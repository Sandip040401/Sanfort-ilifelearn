<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- AR Fragment (full screen background) -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/arFragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ==================== TOP HEADER ==================== -->

    <View
        android:id="@+id/topGradient"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@android:color/transparent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Back Button -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:background="@android:color/transparent"
        android:contentDescription="Back"
        android:elevation="8dp"
        android:scaleType="centerInside"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Model Name Badge -->
    <TextView
        android:id="@+id/modelNameText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="5dp"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:letterSpacing="0.04"
        android:visibility="gone"
        android:elevation="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Close Button -->
    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:background="@android:color/transparent"
        android:contentDescription="Close"
        android:elevation="8dp"
        android:scaleType="centerInside"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Live Coloring Status -->
    <LinearLayout
        android:id="@+id/liveColoringContainer"
        android:layout_width="wrap_content"
        android:layout_height="20dp"
        android:layout_marginTop="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:elevation="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/modelNameText">

        <View
            android:id="@+id/liveColoringDot"
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/liveColoringLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live Coloring"
            android:textColor="#FFFFFF"
            android:textSize="8sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/liveColoringStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="ON"
            android:textColor="#00E676"
            android:textSize="8sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Hidden menu button -->
    <ImageButton
        android:id="@+id/btnMenu"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@android:color/transparent"
        android:contentDescription="Menu"
        android:scaleType="centerInside"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- ==================== GAME-STYLE BOTTOM UI — buttons on sides ==================== -->

    <!-- Transparent background strip at bottom (minimal) -->
    <View
        android:id="@+id/bottomPanelBg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/bottomPanelContent" />

    <LinearLayout
        android:id="@+id/bottomPanelContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="6dp"
        android:paddingHorizontal="12dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- LEFT: Audio Button — game-style round pill -->
        <LinearLayout
            android:id="@+id/audioButtonContainer"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <ImageButton
                android:id="@+id/btnAudio"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="Play Audio"
                android:scaleType="centerInside"
                android:background="@android:color/transparent" />

            <TextView
                android:id="@+id/audioLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Let's Spell"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- CENTER: spacer + instruction text -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/instructionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Point camera at the coloring page"
                android:textColor="#B3FFFFFF"
                android:textSize="9sp"
                android:maxLines="2"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- RIGHT: Color Toggle — game-style round pill -->
        <LinearLayout
            android:id="@+id/toggleColoursContainer"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <TextView
                android:id="@+id/toggleModeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:text="Real Look"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <Switch
                android:id="@+id/switchToggleColours"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:thumbTint="#00E5FF"
                android:trackTint="#4DFFFFFF" />

        </LinearLayout>

    </LinearLayout>

    <!-- ==================== LOADING OVERLAY ==================== -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#E6000000"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="32dp">

            <ProgressBar
                android:id="@+id/loadingProgress"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:indeterminateTint="#00E5FF" />

            <TextView
                android:id="@+id/loadingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Loading 3D model..."
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Please wait a moment"
                android:textColor="#80FFFFFF"
                android:textSize="9sp" />

        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
