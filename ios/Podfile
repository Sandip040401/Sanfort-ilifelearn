# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'iLifeLearn' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Fix Xcode 15/16 "non-modular-include-in-framework-module" errors
    # seen with some RN pods under New Architecture builds.
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        config.build_settings['CLANG_WARN_NON_MODULAR_INCLUDE_IN_FRAMEWORK_MODULE'] = 'NO'
        # Some pods still pass -Werror; force-disable it here.
        other_cflags = config.build_settings['OTHER_CFLAGS'] || ['$(inherited)']
        other_cflags = Array(other_cflags)
        other_cflags << '-Wno-non-modular-include-in-framework-module'
        other_cflags << '-Wno-error=non-modular-include-in-framework-module'
        config.build_settings['OTHER_CFLAGS'] = other_cflags

        other_cxxflags = config.build_settings['OTHER_CPLUSPLUSFLAGS'] || ['$(inherited)']
        other_cxxflags = Array(other_cxxflags)
        other_cxxflags << '-Wno-non-modular-include-in-framework-module'
        other_cxxflags << '-Wno-error=non-modular-include-in-framework-module'
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] = other_cxxflags

        # NitroModules uses Swift C++ interop (std::, exception_ptr, etc).
        # Ensure interop is enabled for Xcode 15/16 toolchains.
        if target.name == 'NitroModules'
          config.build_settings['SWIFT_CXX_INTEROP_MODE'] = 'default'
          config.build_settings['SWIFT_ENABLE_EXPERIMENTAL_FEATURES'] = 'CxxInterop'
        end
      end
    end

    # RN 0.84.1 can generate a malformed Hermes flag for React-RCTAppDelegate:
    #   -DRCT_NEW_ARCH_ENABLED=1-DUSE_HERMES=1
    # That corrupts ObjC++/C++ pod compilation under the New Architecture.
    react_rct_app_delegate_xcconfigs = Dir.glob(
      File.join(__dir__, 'Pods', 'Target Support Files', 'React-RCTAppDelegate', 'React-RCTAppDelegate*.xcconfig')
    )
    react_rct_app_delegate_xcconfigs.each do |xcconfig_path|
      next unless File.exist?(xcconfig_path)

      xcconfig_source = File.read(xcconfig_path)
      xcconfig_fixed = xcconfig_source.gsub(
        '-DRCT_NEW_ARCH_ENABLED=1-DUSE_HERMES=1',
        '-DRCT_NEW_ARCH_ENABLED=1 -DUSE_HERMES=1'
      )

      next if xcconfig_fixed == xcconfig_source

      File.write(xcconfig_path, xcconfig_fixed)
      Pod::UI.puts "Patched malformed Hermes flags in #{File.basename(xcconfig_path)}"
    end
  end
end
